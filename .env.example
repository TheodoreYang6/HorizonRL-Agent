# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# HorizonRL-Agent 环境变量配置模板
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 复制此文件为 .env 并填入真实的 API Key。
# .env 文件不会被 git 追踪。
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# ── LLM API Keys ──────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# ── 搜索 API Keys（可选）──────────────────────────────────────────────
# 国内推荐 Bocha，国际可选 Brave
BOCHA_API_KEY=
BRAVE_API_KEY=

# ── 运行模式 ──────────────────────────────────────────────────────────
# search_provider: auto | bocha | brave | duckduckgo | mock
#   auto = Bocha → Brave → DuckDuckGo → Mock 自动 fallback
HORIZON_SEARCH_PROVIDER=auto
HORIZON_OFFLINE_MODE=false
ENABLE_LLM_WRITER=true

# ── 配置覆盖（可选，优先级高于 YAML 文件）─────────────────────────────
# 格式：HORIZON_<SECTION>_<KEY>=<value>
# 示例：HORIZON_LLM_MODEL=gpt-4o
#       HORIZON_AGENT_MAX_STEPS=20
