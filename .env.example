# ═══════════════════════════════════════════════════════════════════════════════
# HorizonRL-Agent 环境变量配置模板
# ═══════════════════════════════════════════════════════════════════════════════
# 复制此文件为 .env 并填入真实的 API Key。.env 不会被 git 追踪。
#
# 配置优先级 (从低到高):
#   1. Pydantic 代码默认值 (settings.py)
#   2. configs/default.yaml
#   3. configs/dev.yaml / eval.yaml (通过 --config 指定)
#   4. .env 文件
#   5. 直接设置的环境变量 (export HORIZON_XXX=yyy)
#
# 环境变量命名规则:
#   - HORIZON_<SECTION>__<KEY>=<value>  (双下划线 __ 表示嵌套)
#   - 例如: HORIZON_LLM__MODEL=gpt-4o → config.llm.model = "gpt-4o"
#   - 例如: HORIZON_MEMORY__L3_BACKEND=chromadb → config.memory.l3_backend = "chromadb"
# ═══════════════════════════════════════════════════════════════════════════════


# ═══════════════════════════════════════════════════════════════════════════════
# 一、API Key (必填 — 至少配置一个 LLM Key)
# ═══════════════════════════════════════════════════════════════════════════════

# DeepSeek API (推荐，OpenAI 兼容，国内可用)
DEEPSEEK_API_KEY=sk-your-deepseek-key-here

# OpenAI API (备选)
OPENAI_API_KEY=sk-your-openai-key-here

# Anthropic Claude API (备选)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# 阿里云百炼 DashScope Embedding API (L3 向量嵌入)
DASHSCOPE_API_KEY=sk-your-dashscope-key-here

# ═══════════════════════════════════════════════════════════════════════════════
# 二、Web 搜索 API Key (可选 — 不配置则使用免费后端)
# ═══════════════════════════════════════════════════════════════════════════════

# BochaAI 搜索 API (国内推荐，首选)
BOCHA_API_KEY=sk-your-bocha-key-here

# Brave Search API (国际备选)
BRAVE_API_KEY=


# ═══════════════════════════════════════════════════════════════════════════════
# 三、Web 服务配置
# ═══════════════════════════════════════════════════════════════════════════════

# Web 服务端口
# HORIZON_WEB_PORT=8000
PORT=8000

# 会话存储后端: memory (开发/测试, 重启丢失) | sqlite (生产, 持久化)
SESSION_BACKEND=sqlite

# SQLite 数据库路径 (SESSION_BACKEND=sqlite 时生效)
# SESSION_DB_PATH=data/sessions.db

# ═══════════════════════════════════════════════════════════════════════════════
# 四、LLM 配置 (HORIZON_LLM__* / HORIZON_LIGHTWEIGHT_LLM__* / HORIZON_EMBEDDING__*)
# ═══════════════════════════════════════════════════════════════════════════════

# ── 主推理模型 ──
# HORIZON_LLM__PROVIDER=deepseek
# HORIZON_LLM__MODEL=deepseek-chat
# HORIZON_LLM__TEMPERATURE=0.3
# HORIZON_LLM__MAX_TOKENS=4096
# HORIZON_LLM__BASE_URL=https://api.deepseek.com

# ── 轻量模型 (L2 摘要压缩、简单分类) ──
# HORIZON_LIGHTWEIGHT_LLM__PROVIDER=deepseek
# HORIZON_LIGHTWEIGHT_LLM__MODEL=deepseek-chat
# HORIZON_LIGHTWEIGHT_LLM__TEMPERATURE=0.0
# HORIZON_LIGHTWEIGHT_LLM__MAX_TOKENS=1024
# HORIZON_LIGHTWEIGHT_LLM__BASE_URL=https://api.deepseek.com

# ── Embedding 模型 (L3 向量检索) ──
# HORIZON_EMBEDDING__PROVIDER=dashscope
# HORIZON_EMBEDDING__MODEL=text-embedding-v4
# HORIZON_EMBEDDING__BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ═══════════════════════════════════════════════════════════════════════════════
# 五、分层记忆配置 (HORIZON_MEMORY__*)
# ═══════════════════════════════════════════════════════════════════════════════

# L1 最近窗口 token 上限 (超限触发 L1→L2 压缩)
# HORIZON_MEMORY__L1_MAX_TOKENS=10000

# L1 自动压缩阈值 (0.0~1.0, 使用率超过此比例触发)
# HORIZON_MEMORY__AUTO_COMPRESS_THRESHOLD=0.8

# L2 语义压缩使用的模型
# HORIZON_MEMORY__L2_SUMMARY_MODEL=deepseek-chat

# L2 最多保留的语义摘要条目数 (超限 FIFO 淘汰)
# HORIZON_MEMORY__L2_MAX_ENTRIES=50

# L3 向量存储后端: faiss (默认, 零依赖) | chromadb (推荐生产, 支持元数据过滤)
# HORIZON_MEMORY__L3_BACKEND=faiss

# L3 向量嵌入模型
# HORIZON_MEMORY__L3_EMBEDDING_MODEL=text-embedding-v4

# L3 索引持久化路径
# HORIZON_MEMORY__L3_INDEX_PATH=.memory/episodic_index

# 单次检索返回的最大结果数
# HORIZON_MEMORY__RETRIEVAL_TOP_K=5

# ═══════════════════════════════════════════════════════════════════════════════
# 六、Agent 执行配置 (HORIZON_AGENT__*)
# ═══════════════════════════════════════════════════════════════════════════════

# 单任务最大执行步数
# HORIZON_AGENT__MAX_STEPS=30

# 同时执行的 Worker 最大数量 (asyncio.Semaphore)
# HORIZON_AGENT__WORKER_SEMAPHORE_LIMIT=3

# 单个子任务总超时(秒)
# HORIZON_AGENT__TASK_TIMEOUT=120

# 单次 LLM 调用超时(秒)
# HORIZON_AGENT__LLM_CALL_TIMEOUT=30

# 单次工具调用超时(秒)
# HORIZON_AGENT__TOOL_CALL_TIMEOUT=12

# 单个子任务最多重试次数
# HORIZON_AGENT__MAX_RETRIES_PER_TASK=3

# 单次任务最多重规划次数 (防止死循环)
# HORIZON_AGENT__REPLAN_MAX_ITERATIONS=5

# ═══════════════════════════════════════════════════════════════════════════════
# 七、验证器配置 (HORIZON_VERIFIER__*)
# ═══════════════════════════════════════════════════════════════════════════════

# 严格模式 (提高证据数量和质量要求)
# HORIZON_VERIFIER__STRICT_MODE=false

# 最少证据数量 (低于此值判定为证据不足)
# HORIZON_VERIFIER__MIN_EVIDENCE_COUNT=1

# ═══════════════════════════════════════════════════════════════════════════════
# 八、轨迹日志配置 (HORIZON_LOGGING__*)
# ═══════════════════════════════════════════════════════════════════════════════

# 输出格式: jsonl | parquet
# HORIZON_LOGGING__FORMAT=jsonl

# 轨迹文件输出目录
# HORIZON_LOGGING__OUTPUT_DIR=data/traces

# 是否同时输出到控制台
# HORIZON_LOGGING__LOG_TO_CONSOLE=false

# 内存缓冲事件数 (攒够再写入磁盘)
# HORIZON_LOGGING__BUFFER_SIZE=100

# 强制刷新间隔(秒, buffer 未满也写入)
# HORIZON_LOGGING__FLUSH_INTERVAL=5

# ═══════════════════════════════════════════════════════════════════════════════
# 九、工具配置 (HORIZON_TOOLS__<TOOL>__<KEY>)
# ═══════════════════════════════════════════════════════════════════════════════

# ── Web 搜索 ──
# HORIZON_TOOLS__WEB_SEARCH__ENGINE=auto
# HORIZON_TOOLS__WEB_SEARCH__MAX_RESULTS=10
# HORIZON_TOOLS__WEB_SEARCH__TIMEOUT=12

# ── 学术论文搜索 ──
# HORIZON_TOOLS__PAPER_SEARCH__MAX_RESULTS=20
# HORIZON_TOOLS__PAPER_SEARCH__TIMEOUT=15
# HORIZON_TOOLS__PAPER_SEARCH__RATE_LIMIT_PER_MINUTE=10

# ── Arxiv 搜索 ──
# HORIZON_TOOLS__ARXIV_SEARCH__MAX_RESULTS=20
# HORIZON_TOOLS__ARXIV_SEARCH__TIMEOUT=12

# ── 代码执行 ──
# HORIZON_TOOLS__CODE_EXECUTION__SANDBOX=subprocess
# HORIZON_TOOLS__CODE_EXECUTION__TIMEOUT=30
# HORIZON_TOOLS__CODE_EXECUTION__MAX_OUTPUT_CHARS=10000

# ═══════════════════════════════════════════════════════════════════════════════
# 十、顶层配置
# ═══════════════════════════════════════════════════════════════════════════════

# 调试模式 (true 输出更多日志)
# HORIZON_DEBUG=false

# 日志级别: DEBUG | INFO | WARNING | ERROR
# HORIZON_LOG_LEVEL=INFO

# 日志文件目录
# HORIZON_LOG_DIR=logs

# ═══════════════════════════════════════════════════════════════════════════════
# 十一、快速场景模板
# ═══════════════════════════════════════════════════════════════════════════════
#
# 开发环境:
#   HORIZON_DEBUG=true
#   HORIZON_LOG_LEVEL=DEBUG
#   HORIZON_LOGGING__LOG_TO_CONSOLE=true
#   HORIZON_LLM__TEMPERATURE=0.5
#   SESSION_BACKEND=memory
#
# 生产部署:
#   HORIZON_DEBUG=false
#   HORIZON_LOG_LEVEL=WARNING
#   SESSION_BACKEND=sqlite
#   HORIZON_MEMORY__L3_BACKEND=chromadb
#   HORIZON_AGENT__WORKER_SEMAPHORE_LIMIT=4
#
# 评测环境:
#   HORIZON_LLM__TEMPERATURE=0.0
#   HORIZON_VERIFIER__STRICT_MODE=true
#   HORIZON_VERIFIER__MIN_EVIDENCE_COUNT=3
#   HORIZON_AGENT__REPLAN_MAX_ITERATIONS=5
# ═══════════════════════════════════════════════════════════════════════════════
